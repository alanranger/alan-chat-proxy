# Copy to .env.local and fill values from Supabase Dashboard → Settings → API.
# IMPORTANT: SERVICE_ROLE_KEY and ANON_KEY must belong to the SAME project as SUPABASE_URL
# (decode JWT payload "ref"; it must match the hostname xxx.supabase.co).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
